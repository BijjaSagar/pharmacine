<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PharmacySystem.Desktop.ViewModels"
        x:Class="PharmacySystem.Desktop.Views.ReportView"
        Title="Pharmacy System - Reports" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <vm:ReportViewModel />
    </Window.DataContext>

    <Grid Margin="15" RowDefinitions="Auto,Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" Background="#3B82F6" Padding="15" CornerRadius="5" Margin="0,0,0,15">
            <TextBlock Text="Reporting Suite" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
        </Border>

        <!-- Filters -->
        <Border Grid.Row="1" Background="White" CornerRadius="5" Padding="15" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" Spacing="20">
                <TextBlock Text="Date Range:" VerticalAlignment="Center" FontWeight="Bold"/>
                <DatePicker SelectedDate="{Binding StartDate}" />
                <TextBlock Text="to" VerticalAlignment="Center" />
                <DatePicker SelectedDate="{Binding EndDate}" />
                <Button Content="APPLY FILTERS" Command="{Binding LoadReportsCommand}" Background="#10B981" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="2">
            <!-- Sales Report -->
            <TabItem Header="Sales Report">
                <Grid RowDefinitions="*,Auto">
                    <DataGrid Grid.Row="0" ItemsSource="{Binding SalesReport}" AutoGenerateColumns="False" IsReadOnly="True" Background="White" RowHeight="35">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding SaleDate, StringFormat={}{0:g}}" Width="150" />
                            <DataGridTextColumn Header="Invoice No" Binding="{Binding InvoiceNo}" Width="150" />
                            <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*" />
                            <DataGridTextColumn Header="Payment" Binding="{Binding PaymentMode}" Width="120" />
                            <DataGridTextColumn Header="Total Amount" Binding="{Binding TotalAmount, StringFormat={}{0:C2}}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Button Grid.Row="1" Content="Export Sales to CSV" Command="{Binding ExportCommand}" CommandParameter="Sales" 
                            Background="#F59E0B" Foreground="White" FontWeight="Bold" Margin="0,10,0,0" HorizontalAlignment="Right"/>
                </Grid>
            </TabItem>

            <!-- Stock Ageing Report -->
            <TabItem Header="Stock &amp; Ageing">
                <Grid RowDefinitions="*,Auto">
                    <DataGrid Grid.Row="0" ItemsSource="{Binding StockReport}" AutoGenerateColumns="False" IsReadOnly="True" Background="White" RowHeight="35">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*" />
                            <DataGridTextColumn Header="Batch" Binding="{Binding BatchNumber}" Width="150" />
                            <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100" />
                            <DataGridTextColumn Header="Expiry Date" Binding="{Binding ExpiryDate, StringFormat={}{0:d}}" Width="120" />
                            <DataGridTextColumn Header="Age (Days)" Binding="{Binding AgeInDays}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Button Grid.Row="1" Content="Export Stock to CSV" Command="{Binding ExportCommand}" CommandParameter="Stock" 
                            Background="#F59E0B" Foreground="White" FontWeight="Bold" Margin="0,10,0,0" HorizontalAlignment="Right"/>
                </Grid>
            </TabItem>

            <!-- GST Summary -->
            <TabItem Header="GST Summary">
                <Grid RowDefinitions="*,Auto">
                    <DataGrid Grid.Row="0" ItemsSource="{Binding GstReport}" AutoGenerateColumns="False" IsReadOnly="True" Background="White" RowHeight="35">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding SaleDate, StringFormat={}{0:d}}" Width="120" />
                            <DataGridTextColumn Header="Invoice No" Binding="{Binding InvoiceNo}" Width="150" />
                            <DataGridTextColumn Header="Taxable Amount" Binding="{Binding TaxableAmount, StringFormat={}{0:C2}}" Width="150" />
                            <DataGridTextColumn Header="GST Amount" Binding="{Binding GstAmount, StringFormat={}{0:C2}}" Width="120" />
                            <DataGridTextColumn Header="Total Amount" Binding="{Binding TotalAmount, StringFormat={}{0:C2}}" Width="150" />
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Button Grid.Row="1" Content="Export GST to CSV" Command="{Binding ExportCommand}" CommandParameter="GST" 
                            Background="#F59E0B" Foreground="White" FontWeight="Bold" Margin="0,10,0,0" HorizontalAlignment="Right"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="3" Background="#FFFBEB" Padding="10" CornerRadius="5" Margin="0,15,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#B45309" FontWeight="SemiBold" VerticalAlignment="Center" />
        </Border>
    </Grid>
</Window>
