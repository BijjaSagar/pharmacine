<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PharmacySystem.Desktop.ViewModels"
        x:Class="PharmacySystem.Desktop.Views.StockAdjustmentView"
        Title="Pharmacy System - Stock Adjustment" Height="500" Width="800"
        WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <vm:StockAdjustmentViewModel />
    </Window.DataContext>

    <Grid Margin="15" RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" Background="#F59E0B" Padding="15" CornerRadius="5" Margin="0,0,0,15">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Text="Stock Adjustment" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,15,0">
                    <TextBlock Text="Scan Barcode: " Foreground="White" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Text="{Binding BarcodeInput}" Width="200" Height="30" VerticalContentAlignment="Center" 
                             Watermark="Press Enter to Search">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" Command="{Binding SearchCommand}" />
                        </TextBox.KeyBindings>
                    </TextBox>
                    <Button Content="Search" Command="{Binding SearchCommand}" Margin="10,0,0,0" Width="80" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Batches Grid -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Batches}" SelectedItem="{Binding SelectedBatch}" 
                  AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="All" Background="White" RowHeight="40">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*" />
                <DataGridTextColumn Header="Batch No" Binding="{Binding BatchNumber}" Width="150" />
                <DataGridTextColumn Header="Current Qty" Binding="{Binding CurrentQuantity}" Width="100" />
                <DataGridTextColumn Header="Expiry Date" Binding="{Binding ExpiryDate, StringFormat={}{0:d}}" Width="150" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer / Action Area -->
        <Border Grid.Row="2" Background="#FFFBEB" Padding="20" CornerRadius="5" Margin="0,15,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" FontWeight="Bold" VerticalAlignment="Center" TextWrapping="Wrap" />
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" IsEnabled="{Binding SelectedBatch, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <TextBlock Text="New Qty: " VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                    <NumericUpDown Value="{Binding NewQuantity}" Minimum="0" Width="100" Margin="0,0,20,0"/>

                    <TextBlock Text="Reason: " VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                    <ComboBox ItemsSource="{Binding Reasons}" SelectedItem="{Binding Reason}" Width="150" Margin="0,0,20,0"/>

                    <Button Content="APPLY ADJUSTMENT" Command="{Binding AdjustStockCommand}" Background="#F59E0B" Foreground="White" FontSize="16" FontWeight="Bold" 
                            Height="40" Width="180" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
