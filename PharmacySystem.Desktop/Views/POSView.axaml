<Window xmlns="https://github.com/avaloniaui"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PharmacySystem.Desktop.ViewModels"
        x:Class="PharmacySystem.Desktop.Views.POSView"
        Title="ClinicOS — Point of Sale"
        Width="1400" Height="820"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8"
        KeyDown="Window_KeyDown">

    <Window.DataContext>
        <vm:SaleViewModel />
    </Window.DataContext>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- TOP BAR  -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#1E293B" Padding="12,8">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Text="🏥  ClinicOS — Point of Sale"
                           Foreground="White" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <!-- Keyboard legend -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                            VerticalAlignment="Center" Spacing="18">
                    <TextBlock Text="F2 = Search" Foreground="#94A3B8" FontSize="12"/>
                    <TextBlock Text="F3 = Quick Add  |  F5 = Checkout  |  F9 = Find Substitute" Foreground="#94A3B8" FontSize="12"/>
                    <TextBlock Text="F8 = Cancel Bill" Foreground="#94A3B8" FontSize="12"/>
                    <TextBlock Text="Ctrl+1…0 = Switch Console" Foreground="#94A3B8" FontSize="12"/>
                    <TextBlock Text="Enter = Add Item" Foreground="#94A3B8" FontSize="12"/>
                    <TextBlock Text="Del = Remove Row" Foreground="#94A3B8" FontSize="12"/>
                </StackPanel>
                <TextBlock Grid.Column="2"
                           Text="{Binding ActiveConsole.Header, StringFormat='Active: {0}'}"
                           Foreground="#38BDF8" FontSize="14" FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- CONSOLE TABS  (Console 1 … Console 10) -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#0F172A" Padding="4,0,4,0">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Consoles}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.SwitchConsoleCommand,
                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding ConsoleNumber}"
                                    Padding="16,10" Margin="2,4"
                                    CornerRadius="6,6,0,0"
                                    Cursor="Hand">
                                <Button.Background>
                                    <SolidColorBrush Color="#334155"/>
                                </Button.Background>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding Header}" Foreground="White"
                                               FontSize="13" FontWeight="SemiBold"/>
                                    <Border Background="#EF4444" CornerRadius="8" Padding="4,1"
                                            IsVisible="{Binding ItemCount, Converter={x:Static ObjectConverters.IsNotNull}}">
                                        <TextBlock Text="{Binding ItemCount}" Foreground="White" FontSize="11"/>
                                    </Border>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- MAIN BODY -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" ColumnDefinitions="*,340" Margin="0">

            <!-- LEFT: Bill items -->
            <Grid RowDefinitions="Auto,Auto,*" Margin="12,10,6,0">

                <!-- Customer / Doctor row -->
                <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="12,10"
                        BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,8">
                    <Grid ColumnDefinitions="*,*,*,Auto">
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="👤  Customer Name" FontSize="11" Foreground="#64748B" FontWeight="SemiBold"/>
                            <TextBox x:Name="CustomerNameBox"
                                     Text="{Binding ActiveConsole.CustomerName}"
                                     Watermark="Walk-in / Patient Name"
                                     FontSize="14" Height="34"
                                     Background="#F8FAFC" BorderBrush="#CBD5E1"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                            <TextBlock Text="📞  Phone" FontSize="11" Foreground="#64748B" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding ActiveConsole.CustomerPhone}"
                                     Watermark="Mobile Number"
                                     FontSize="14" Height="34"
                                     Background="#F8FAFC" BorderBrush="#CBD5E1"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="0,0,8,0">
                            <TextBlock Text="🩺  Doctor Name" FontSize="11" Foreground="#64748B" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding ActiveConsole.DoctorName}"
                                     Watermark="Prescribing Doctor"
                                     FontSize="14" Height="34"
                                     Background="#F8FAFC" BorderBrush="#CBD5E1"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3">
                            <TextBlock Text="🏠  Patient Address (H1)" FontSize="11" Foreground="#64748B" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding ActiveConsole.PatientAddress}"
                                     Watermark="Req. for Sch. H1"
                                     FontSize="14" Height="34"
                                     Background="#F8FAFC" BorderBrush="#CBD5E1"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4" Margin="8,0,0,0">
                            <TextBlock Text="🏷  Discount %" FontSize="11" Foreground="#64748B" FontWeight="SemiBold"/>
                            <NumericUpDown Value="{Binding ActiveConsole.DiscountPercent}"
                                          Minimum="0" Maximum="100"
                                          Width="80" Height="34" FontSize="14"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Search Bar -->
                <Border Grid.Row="1" Background="White" CornerRadius="8"
                        BorderBrush="#3B82F6" BorderThickness="2" Margin="0,0,0,6">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                        <TextBox x:Name="SearchBox"
                                 Grid.Column="0"
                                 Text="{Binding SearchInput}"
                                 Watermark="🔍  Type name… (F2) or F9 for Substitutes"
                                 FontSize="15" Background="Transparent" BorderThickness="0"
                                 Padding="14,10"
                                 KeyDown="SearchBox_KeyDown"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                            <TextBlock Text="Qty:" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="SemiBold"/>
                            <NumericUpDown Value="{Binding AddQuantity}"
                                          Minimum="0.25" Increment="0.25"
                                          Width="90" Height="34" FontSize="14"
                                          ToolTip.Tip="Supports half units (0.5, 1.5…)"/>
                        </StackPanel>
                        <Button Grid.Column="2" Content="Add  ↵"
                                Command="{Binding AddToCartCommand}"
                                Background="#3B82F6" Foreground="White"
                                FontSize="14" FontWeight="Bold"
                                Padding="16,8" Margin="4,4,8,4"
                                CornerRadius="6"/>
                    </Grid>
                </Border>

                <!-- Search Dropdown -->
                <Border Grid.Row="2" IsVisible="{Binding IsSearchVisible}"
                        Background="White" CornerRadius="8" BorderBrush="#3B82F6" BorderThickness="1"
                        ZIndex="100" VerticalAlignment="Top" Margin="0,0,0,0" MaxHeight="260">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Background="#EFF6FF" Padding="10,6" CornerRadius="8,8,0,0">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Search Results — click or use ↑↓ Enter to add"
                                           FontSize="12" Foreground="#1E40AF" FontWeight="SemiBold"/>
                                <Button Grid.Column="1" Content="✕ Close" Command="{Binding ClearSearchCommand}"
                                        Background="Transparent" Foreground="#64748B" FontSize="12" Padding="6,2"/>
                            </Grid>
                        </Border>
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding SearchResults}"
                                 SelectedItem="{Binding SelectedSearchResult}"
                                 Background="Transparent" BorderThickness="0"
                                 x:Name="SearchList"
                 KeyDown="SearchList_KeyDown">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,8" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="*,Auto,Auto">
                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A"/>
                                                    <Border IsVisible="{Binding IsScheduleH1}" Background="#EF4444" CornerRadius="4" Padding="4,2" Margin="6,0,0,0">
                                                        <TextBlock Text="H1" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding GenericName}" FontSize="11" Foreground="#64748B"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Category}" FontSize="11" Foreground="#94A3B8"/>
                                                    <Border Background="#F1F5F9" CornerRadius="4" Padding="4,1" Margin="6,0,0,0">
                                                        <TextBlock Text="{Binding ShelfLocation, StringFormat='📍 {0}'}" FontSize="10" FontWeight="SemiBold" Foreground="#475569"/>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="20,0" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding PriceDisplay}" FontSize="14" FontWeight="Bold" Foreground="#10B981"/>
                                                <TextBlock Text="{Binding StockDisplay}" FontSize="11"
                                                           Foreground="{Binding StockAvailable,
                                                               Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding BatchNumber}"
                                                       FontSize="11" Foreground="#94A3B8"
                                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Cart Grid (when no search open) -->
                <DataGrid Grid.Row="2"
                          x:Name="CartGrid"
                          ItemsSource="{Binding ActiveConsole.CartItems}"
                          AutoGenerateColumns="False"
                          IsReadOnly="False"
                          CanUserReorderColumns="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          Background="White"
                          RowHeight="44"
                          FontSize="14"
                          IsVisible="{Binding IsSearchVisible, Converter={x:Static BoolConverters.Not}}"
                          KeyDown="CartGrid_KeyDown">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Width="40" IsReadOnly="True"
                                            Binding="{Binding BatchNumber}"/>
                        <DataGridTextColumn Header="Medicine Name" Width="*" IsReadOnly="True"
                                            Binding="{Binding Product.Name}"/>
                        <DataGridTextColumn Header="Batch" Width="100" IsReadOnly="True"
                                            Binding="{Binding BatchNumber}"/>
                        <DataGridTextColumn Header="Shelf" Width="80" IsReadOnly="True"
                                            Binding="{Binding Product.ShelfLocation}"/>
                        <DataGridTextColumn Header="Stock" Width="70" IsReadOnly="True"
                                            Binding="{Binding StockAvailable}"/>
                        <DataGridTextColumn Header="MRP" Width="90" IsReadOnly="True"
                                            Binding="{Binding Product.UnitPrice, StringFormat={}{0:F2}}"/>
                        <DataGridTemplateColumn Header="Qty" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <NumericUpDown Value="{Binding Quantity}"
                                                       Minimum="0.25" Increment="0.25"
                                                       FontSize="14" Width="90"
                                                       Background="Transparent"/>
                                        <Button Content="½" 
                                                Command="{Binding $parent[DataGrid].DataContext.SplitHalfCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="Split Half (Set Qty to 0.5)"
                                                Background="#E2E8F0" Padding="4,0" Cursor="Hand"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="GST ₹" Width="90" IsReadOnly="True"
                                            Binding="{Binding GstAmount, StringFormat={}{0:F2}}"/>
                        <DataGridTextColumn Header="Total ₹" Width="100" IsReadOnly="True"
                                            Binding="{Binding Total, StringFormat={}{0:F2}}"/>
                        <DataGridTemplateColumn Header="Del" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✕"
                                            Command="{Binding DataContext.RemoveFromCartCommand,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" Foreground="#EF4444"
                                            FontSize="16" FontWeight="Bold" Padding="4"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- RIGHT: Totals + Actions -->
            <Border Grid.Column="1" Background="White" Margin="6,10,12,0" CornerRadius="10"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid RowDefinitions="Auto,*,Auto">

                    <!-- Console Summary Header -->
                    <Border Grid.Row="0" Background="#1E293B" CornerRadius="10,10,0,0" Padding="16,12">
                        <StackPanel>
                            <TextBlock Text="{Binding ActiveConsole.Header}"
                                       Foreground="White" FontSize="20" FontWeight="Heavy"/>
                            <TextBlock Text="{Binding ActiveConsole.CustomerName, StringFormat='Customer: {0}'}"
                                       Foreground="#94A3B8" FontSize="13"/>
                            <TextBlock Text="{Binding ActiveConsole.DoctorName, StringFormat='Dr. {0}'}"
                                       Foreground="#64748B" FontSize="12"
                                       IsVisible="{Binding ActiveConsole.DoctorName,
                                           Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        </StackPanel>
                    </Border>

                    <!-- Totals -->
                    <StackPanel Grid.Row="1" Margin="16,16,16,0" Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Sub Total" Foreground="#64748B" FontSize="15"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ActiveConsole.SubTotal, StringFormat='₹ {0:F2}'}"
                                       FontSize="15" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="GST" Foreground="#64748B" FontSize="15"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ActiveConsole.TotalGst, StringFormat='₹ {0:F2}'}"
                                       FontSize="15"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding ActiveConsole.HasRewardPoints}">
                            <TextBlock Text="Loyalty Points Available" Foreground="#8B5CF6" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="{Binding ActiveConsole.AvailableRewardPoints}" Foreground="#8B5CF6" FontSize="13" FontWeight="Bold"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding ActiveConsole.DiscountPercent, StringFormat='Discount ({0}%)'}"
                                       Foreground="#EF4444" FontSize="15"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ActiveConsole.DiscountAmount, StringFormat='- ₹ {0:F2}'}"
                                       Foreground="#EF4444" FontSize="15"/>
                        </Grid>
                        <Separator Background="#E2E8F0"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="GRAND TOTAL" FontSize="20" FontWeight="Heavy" Foreground="#1E293B"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ActiveConsole.GrandTotal, StringFormat='₹ {0:F2}'}"
                                       FontSize="22" FontWeight="Heavy" Foreground="#10B981"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Items in cart" Foreground="#94A3B8" FontSize="13"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ActiveConsole.ItemCount}"
                                       Foreground="#94A3B8" FontSize="13"/>
                        </Grid>
                        
                        <Separator Background="#E2E8F0" Margin="0,4"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Payment Mode:" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" Width="100" SelectedItem="{Binding ActiveConsole.PaymentMode}" ItemsSource="{Binding ActiveConsole.PaymentModes}" />
                        </Grid>

                        <!-- WhatsApp & Refills -->
                        <Border Background="#F0FDF4" CornerRadius="6" Padding="10">
                            <StackPanel Spacing="6">
                                <CheckBox IsChecked="{Binding ActiveConsole.IsChronicPatient}" Content="Set Refill Reminder (Chronic)" FontSize="13" Foreground="#15803D" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding ActiveConsole.IsChronicPatient}" Margin="20,0,0,0">
                                    <TextBlock Text="Supply Days:" VerticalAlignment="Center" FontSize="12" Foreground="#166534"/>
                                    <NumericUpDown Grid.Column="1" Value="{Binding ActiveConsole.SupplyDays}" Minimum="1" Maximum="180" Width="90" Height="25" FontSize="12"/>
                                </Grid>
                                <CheckBox IsChecked="{Binding ActiveConsole.SendWhatsAppReceipt}" Content="Send WhatsApp Receipt" FontSize="13" Foreground="#15803D" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <!-- AI Co-Pilot -->
                        <Border Background="#F4F4F5" CornerRadius="6" Padding="10" BorderBrush="#E4E4E7" BorderThickness="1">
                            <StackPanel Spacing="6">
                                <TextBlock Text="🤖 Pharma Co-Pilot" FontSize="14" FontWeight="Bold" Foreground="#3F3F46"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Text="{Binding ActiveConsole.CopilotQuery}" Watermark="Ask clinical question..." FontSize="12" Height="30" Padding="8,5" Background="White" CornerRadius="4,0,0,4"/>
                                    <Button Grid.Column="1" Command="{Binding AskCopilotCommand}" Content="Ask" Background="#8B5CF6" Foreground="White" FontSize="12" FontWeight="Bold" Padding="12,5" CornerRadius="0,4,4,0" Cursor="Hand"/>
                                </Grid>
                                <TextBlock Text="{Binding ActiveConsole.CopilotResponse}" IsVisible="{Binding ActiveConsole.CopilotResponse, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" TextWrapping="Wrap" FontSize="11" Foreground="#4F46E5" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Row="2" Margin="12,12,12,16" Spacing="8">
                        <!-- F5 Checkout -->
                        <Button Content="✅  F5 — CHECKOUT &amp; PRINT"
                                Command="{Binding CheckoutCommand}"
                                Background="#10B981" Foreground="White"
                                FontSize="16" FontWeight="Bold"
                                Height="50" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                CornerRadius="8"
                                ToolTip.Tip="Press F5"/>
                        <!-- F8 Cancel -->
                        <Button Content="🗑  F8 — CANCEL BILL"
                                Command="{Binding CancelBillCommand}"
                                Background="#EF4444" Foreground="White"
                                FontSize="14" FontWeight="Bold"
                                Height="40" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                CornerRadius="8"
                                ToolTip.Tip="Press F8"/>
                        <!-- Status line -->
                        <Border Background="#F0FDF4" CornerRadius="6" Padding="10,6"
                                IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap" FontSize="12"
                                       Foreground="#15803D"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- BOTTOM STATUS BAR -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#1E293B" Padding="12,5">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Text="🟢  Connected" Foreground="#4ADE80" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Foreground="#CBD5E1" FontSize="12"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           Text="ClinicOS Pharmacy v1.0"
                           Foreground="#64748B" FontSize="12" VerticalAlignment="Center">
                </TextBlock>
            </Grid>
        </Border>

        <!-- PIN OVERLAY -->
        <Border Grid.Row="0" Grid.RowSpan="4" Background="#80000000" IsVisible="{Binding IsPinRequested}">
            <Border Background="White" CornerRadius="8" Padding="20" HorizontalAlignment="Center" VerticalAlignment="Center" Width="300" BoxShadow="0 4 10 0 #40000000">
                <StackPanel>
                    <TextBlock Text="Manager Override Required" FontSize="16" FontWeight="Bold" Foreground="#DC2626" Margin="0,0,0,15" HorizontalAlignment="Center" />
                    
                    <TextBlock Text="Enter Owner/Manager PIN to proceed:" FontSize="13" Foreground="#475569" Margin="0,0,0,5" />
                    <TextBox Text="{Binding EnteredPin}" PasswordChar="*" FontSize="20" HorizontalContentAlignment="Center" Margin="0,0,0,20" MaxLength="4" />

                    <Grid ColumnDefinitions="*,*">
                        <Button Grid.Column="0" Content="CANCEL" Command="{Binding CancelPinCommand}" Background="#E2E8F0" Foreground="#475569" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,5,0" Cursor="Hand" />
                        <Button Grid.Column="1" Content="AUTHORIZE" Command="{Binding ConfirmPinCommand}" Background="#DC2626" Foreground="White" FontWeight="Bold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="5,0,0,0" Cursor="Hand" />
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

    </Grid>
</Window>
