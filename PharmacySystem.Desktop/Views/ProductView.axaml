<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PharmacySystem.Desktop.ViewModels"
        x:Class="PharmacySystem.Desktop.Views.ProductView"
        Title="Pharmacy System - Product Master" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <vm:ProductViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Form Area -->
        <Border Grid.Column="0" BorderBrush="LightGray" BorderThickness="1" Padding="15" Margin="0,0,10,0" Background="#F9F9F9">
            <StackPanel>
                <TextBlock Text="Product Details" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="#007ACC" />

                <TextBlock Text="Barcode *" FontWeight="SemiBold" />
                <TextBox Text="{Binding SelectedProduct.Barcode}" Margin="0,5,0,10" Height="25" />

                <TextBlock Text="Name *" FontWeight="SemiBold" />
                <TextBox Text="{Binding SelectedProduct.Name}" Margin="0,5,0,10" Height="25" />

                <TextBlock Text="Generic Name" FontWeight="SemiBold" />
                <TextBox Text="{Binding SelectedProduct.GenericName}" Margin="0,5,0,10" Height="25" />

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Pack Size" FontWeight="SemiBold" />
                        <TextBox Text="{Binding SelectedProduct.PackSize}" Margin="0,5,0,0" Height="25" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Reorder Level" FontWeight="SemiBold" />
                        <TextBox Text="{Binding SelectedProduct.ReorderLevel}" Margin="0,5,0,0" Height="25" />
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Unit Price *" FontWeight="SemiBold" />
                        <TextBox Text="{Binding SelectedProduct.UnitPrice}" Margin="0,5,0,0" Height="25" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="GST %" FontWeight="SemiBold" />
                        <TextBox Text="{Binding SelectedProduct.GstPercent}" Margin="0,5,0,0" Height="25" />
                    </StackPanel>
                </Grid>

                <CheckBox Content="Prescription Required" IsChecked="{Binding SelectedProduct.IsPrescriptionRequired}" Margin="0,0,0,5" />
                <CheckBox Content="Schedule H1" IsChecked="{Binding SelectedProduct.IsScheduleH1}" Margin="0,0,0,10" />

                <TextBlock Text="Shelf Location" FontWeight="SemiBold" />
                <TextBox Text="{Binding SelectedProduct.ShelfLocation}" Margin="0,5,0,10" Height="25" Watermark="e.g. Rack A2" />

                <CheckBox Content="Is Active" IsChecked="{Binding SelectedProduct.IsActive}" Margin="0,0,0,20" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Save" Command="{Binding SaveCommand}" Height="35" Background="#007ACC" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                    <Button Grid.Column="2" Content="Clear" Command="{Binding ClearCommand}" Height="35" Background="LightGray" FontWeight="Bold" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- DataGrid Area -->
        <DataGrid Grid.Column="1" ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}" 
                  AutoGenerateColumns="False" IsReadOnly="True" 
                  HeadersVisibility="All" Background="White" RowHeight="30">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ProductId}" Width="40" />
                <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" Width="100" />
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150" />
                <DataGridTextColumn Header="Generic" Binding="{Binding GenericName}" Width="100" />
                <DataGridTextColumn Header="Price" Binding="{Binding UnitPrice, StringFormat={}{0:C}}" Width="80" />
                <DataGridTextColumn Header="GST%" Binding="{Binding GstPercent}" Width="50" />
                <DataGridTextColumn Header="Reorder" Binding="{Binding ReorderLevel}" Width="60" />
                <DataGridTextColumn Header="Shelf" Binding="{Binding ShelfLocation}" Width="80" />
                <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="50" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
