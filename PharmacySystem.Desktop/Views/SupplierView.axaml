<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PharmacySystem.Desktop.ViewModels"
        x:Class="PharmacySystem.Desktop.Views.SupplierView"
        Title="Pharmacy System - Supplier Master" Height="500" Width="850"
        WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <vm:SupplierViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Form Area -->
        <Border Grid.Column="0" BorderBrush="LightGray" BorderThickness="1" Padding="15" Margin="0,0,10,0" Background="#F9F9F9">
            <StackPanel>
                <TextBlock Text="Supplier Details" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="#007ACC" />

                <TextBlock Text="Company Name *" FontWeight="SemiBold" />
                <TextBox Text="{Binding SelectedSupplier.Name}" Margin="0,5,0,10" Height="25" />

                <TextBlock Text="GST Number" FontWeight="SemiBold" />
                <TextBox Text="{Binding SelectedSupplier.Gst}" Margin="0,5,0,10" Height="25" />

                <TextBlock Text="Contact Person" FontWeight="SemiBold" />
                <TextBox Text="{Binding SelectedSupplier.ContactPerson}" Margin="0,5,0,10" Height="25" />

                <TextBlock Text="Phone" FontWeight="SemiBold" />
                <TextBox Text="{Binding SelectedSupplier.Phone}" Margin="0,5,0,10" Height="25" />

                <TextBlock Text="Email" FontWeight="SemiBold" />
                <TextBox Text="{Binding SelectedSupplier.Email}" Margin="0,5,0,10" Height="25" />

                <TextBlock Text="Address" FontWeight="SemiBold" />
                <TextBox Text="{Binding SelectedSupplier.Address}" Margin="0,5,0,15" Height="50" AcceptsReturn="True" TextWrapping="Wrap" />

                <CheckBox Content="Is Active" IsChecked="{Binding SelectedSupplier.IsActive}" Margin="0,0,0,20" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Save" Command="{Binding SaveCommand}" Height="35" Background="#007ACC" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                    <Button Grid.Column="2" Content="Clear" Command="{Binding ClearCommand}" Height="35" Background="LightGray" FontWeight="Bold" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- DataGrid Area -->
        <DataGrid Grid.Column="1" ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" 
                  AutoGenerateColumns="False" IsReadOnly="True" 
                  HeadersVisibility="All" Background="White" RowHeight="30">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding SupplierId}" Width="40" />
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150" />
                <DataGridTextColumn Header="GST" Binding="{Binding Gst}" Width="100" />
                <DataGridTextColumn Header="Contact" Binding="{Binding ContactPerson}" Width="100" />
                <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="100" />
                <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="50" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
