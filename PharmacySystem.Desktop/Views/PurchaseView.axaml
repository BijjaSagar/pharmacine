<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PharmacySystem.Desktop.ViewModels"
        x:Class="PharmacySystem.Desktop.Views.PurchaseView"
        Title="Pharmacy System - Purchase Entry" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <vm:PurchaseViewModel />
    </Window.DataContext>

    <Grid Margin="15" RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" Background="#6F42C1" Padding="15" CornerRadius="5" Margin="0,0,0,15">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Text="Purchase Order Entry" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,15,0">
                    <TextBlock Text="Supplier: " Foreground="White" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" 
                              Width="200" Margin="0,0,15,0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    
                    <TextBlock Text="Inv No: " Foreground="White" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Text="{Binding InvoiceNo}" Width="120" Height="30" Margin="0,0,20,0"/>

                    <TextBlock Text="Scan: " Foreground="White" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Text="{Binding BarcodeInput}" Width="150" Height="30" VerticalContentAlignment="Center" 
                             Watermark="Barcode">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" Command="{Binding ScanCommand}" />
                        </TextBox.KeyBindings>
                    </TextBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Purchase Grid -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding PurchaseItems}" AutoGenerateColumns="False" 
                  IsReadOnly="False" HeadersVisibility="All" Background="White" RowHeight="40">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Item Name" Binding="{Binding Product.Name}" Width="*" IsReadOnly="True" />
                <DataGridTextColumn Header="Batch No" Binding="{Binding BatchNumber}" Width="120" />
                <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="80" />
                <DataGridTextColumn Header="Cost Price" Binding="{Binding CostPrice}" Width="100" />
                <DataGridTextColumn Header="MRP" Binding="{Binding Mrp}" Width="100" />
                <DataGridTextColumn Header="Expiry Date (MM/DD/YYYY)" Binding="{Binding ExpiryDate}" Width="150" />
                <DataGridTextColumn Header="Total Cost" Binding="{Binding TotalCost, StringFormat={}{0:C}}" Width="120" IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#F0F8FF" Padding="20" CornerRadius="5" Margin="0,15,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" FontWeight="Bold" VerticalAlignment="Center" TextWrapping="Wrap" />
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <StackPanel Margin="0,0,30,0">
                        <TextBlock Text="GRAND TOTAL" FontSize="16" Foreground="#6F42C1" FontWeight="Heavy" />
                        <TextBlock Text="{Binding GrandTotal, StringFormat={}{0:C}}" FontSize="28" Foreground="#6F42C1" FontWeight="Heavy" />
                    </StackPanel>

                    <Button Content="SAVE PURCHASE" Command="{Binding SavePurchaseCommand}" Background="#6F42C1" Foreground="White" FontSize="18" FontWeight="Bold" 
                            Height="50" Width="180" VerticalAlignment="Bottom" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
